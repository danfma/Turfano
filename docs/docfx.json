{
  "metadata": [
    {
      "src": [
        {
          "src": "../",
          "files": [
            "src/Turfano/Turfano.csproj",
            "src/Turfano.NetTopologySuite/Turfano.NetTopologySuite.csproj"
          ]
        }
      ],
      "dest": "api",
      "properties": {
        "TargetFramework": "net10.0"
      }
    }
  ],
  "build": {
    "content": [
      {
        "files": ["api/**.yml", "api/index.md"]
      },
      {
        "files": [
          "articles/**.md",
          "articles/**/toc.yml",
          "articles-pt-br/**.md",
          "articles-pt-br/**/toc.yml",
          "toc.yml",
          "*.md"
        ]
      }
    ],
    "resource": [
      {
        "files": ["images/**"]
      }
    ],
    "output": "_site",
    "template": ["default", "modern"],
    "globalMetadata": {
      "_appName": "Turfano",
      "_appTitle": "Turfano — faithful .NET port of TurfJS",
      "_appFooter": "Turfano — MIT. A faithful .NET port of TurfJS over its own GeoJSON types.",
      "_enableSearch": true,
      "_gitContribute": {
        "repo": "https://github.com/danfma/Turfano",
        "branch": "main"
      }
    }
  }
}
